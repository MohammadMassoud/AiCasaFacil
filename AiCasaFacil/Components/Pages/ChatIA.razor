@* AiCasaFacil/Components/Pages/ChatIA.razor *@
@page "/ChatIA"
@rendermode InteractiveServer
@using AiCasaFacil.Application.Services
@using AiCasaFacil.Shared

<PageTitle>Chat IA</PageTitle>

<div class="chat-container">

    <div class="chat-header">
        <i class="bi bi-robot"></i>
        <span>Assistente de Pedidos</span>
        @if (_sessao.TemPedidos)
        {
            <span class="badge bg-success ms-2">@_sessao.Pedidos.Count pedidos carregados</span>
        }
        else
        {
            <span class="badge bg-warning ms-2">Nenhum pedido carregado</span>
        }
    </div>

    <div class="chat-messages" id="chat-messages">
        @if (!_iaService.Historico.Any())
        {
            <div class="chat-empty">
                <i class="bi bi-chat-dots fs-1"></i>
                <p>Olá! Importe uma planilha e me faça perguntas sobre seus pedidos.</p>

                <div class="sugestoes">
                    @foreach (var s in _sugestoes)
                    {
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="() => UsarSugestao(s)">
                            @s
                        </button>
                    }
                </div>
            </div>
        }

        @foreach (var (papel, mensagem) in _iaService.Historico)
        {
            <div class="chat-bubble @(papel == "Usuário" ? "bubble-user" : "bubble-ia")">
                <div class="bubble-header">@papel</div>
                @if (papel == "Assistente")
                {
                    <div class="bubble-text markdown-body">
                        @((MarkupString)MarkdownHelper.ToHtml(mensagem))
                    </div>
                }
                else
                {
                    <div class="bubble-text">@mensagem</div>
                }
            </div>
        }

        @if (_carregando)
        {
            <div class="chat-bubble bubble-ia">
                <div class="bubble-header">Assistente</div>
                <div class="bubble-text typing">
                    <span></span><span></span><span></span>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-area">
        <textarea @bind="_pergunta"
                  @bind:event="oninput"
                  @onkeydown="HandleKeyDown"
                  placeholder="Digite sua pergunta..."
                  rows="2"
                  class="form-control"
                  disabled="@_carregando"></textarea>

        <div class="chat-actions">
            <button class="btn btn-outline-danger btn-sm"
                    @onclick="LimparChat"
                    disabled="@_carregando">
                <i class="bi bi-trash"></i> Limpar
            </button>
            <button class="btn btn-primary"
                    @onclick="Enviar"
                    disabled="@(_carregando || string.IsNullOrWhiteSpace(_pergunta))">
                @if (_carregando)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-send"></i> Enviar
            </button>
        </div>
    </div>

</div>


<style>
    /* AiCasaFacil/Components/Pages/ChatIA.razor.css */
.chat-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 6rem);
    max-width: 860px;
    margin: 0 auto;
}

.chat-header {
    background: linear-gradient(135deg, #052767, #3a0647);
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 12px 12px 0 0;
    font-size: 1.1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    background: #f8f9fa;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.chat-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #888;
    gap: 1rem;
    text-align: center;
}

.sugestoes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 0.5rem;
}

.chat-bubble {
    max-width: 75%;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    line-height: 1.5;
}

.bubble-user {
    align-self: flex-end;
    background: #0d6efd;
    color: white;
    border-bottom-right-radius: 2px;
}

.bubble-ia {
    align-self: flex-start;
    background: white;
    border: 1px solid #dee2e6;
    border-bottom-left-radius: 2px;
}

.bubble-header {
    font-size: 0.7rem;
    font-weight: 600;
    opacity: 0.6;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.chat-input-area {
    background: white;
    border: 1px solid #dee2e6;
    border-top: none;
    border-radius: 0 0 12px 12px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
}

.chat-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
}

/* Animação de digitando */
.typing {
    display: flex;
    gap: 4px;
    align-items: center;
    height: 20px;
}

.typing span {
    width: 8px;
    height: 8px;
    background: #aaa;
    border-radius: 50%;
    animation: bounce 1.2s infinite;
}

.typing span:nth-child(2) { animation-delay: 0.2s; }
.typing span:nth-child(3) { animation-delay: 0.4s; }

@@keyframes bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-6px); }
}

.markdown-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--bs-body-color);
}

.markdown-body p {
    margin: 0 0 0.6rem;
}

.markdown-body p:last-child {
    margin-bottom: 0;
}

.markdown-body ul,
.markdown-body ol {
    margin: 0.4rem 0 0.6rem;
    padding-left: 1.4rem;
}

.markdown-body li {
    margin-bottom: 0.3rem;
}

.markdown-body strong {
    font-weight: 600 !important;
    color: inherit;
}

.markdown-body em {
    font-style: italic;
}

.markdown-body h1,
.markdown-body h2,
.markdown-body h3 {
    font-weight: 600 !important;
    margin: 0.8rem 0 0.4rem;
    font-size: 15px;
}

.markdown-body code {
    background: rgba(0,0,0,0.07);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 13px;
}

.markdown-body hr {
    border: none;
    border-top: 1px solid rgba(0,0,0,0.1);
    margin: 0.8rem 0;
}

</style>